// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Vendor {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  name          String
  slug          String   @unique
  logoUrl       String?  @map("logo_url")
  faviconUrl    String?  @map("favicon_url")
  adminEmails   String[] @map("admin_emails")
  defaultLocale String   @default("ar") @map("default_locale")

  whatsappPhoneNumberId      String? @map("whatsapp_phone_number_id")
  whatsappVerifyToken        String? @map("whatsapp_verify_token")
  supportWhatsapp            String? @map("support_whatsapp")
  metaAccessTokenEncrypted   String? @map("meta_access_token_encrypted")

  events        Event[]

  @@map("vendors")
}

model Event {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  userId           String?  @map("user_id") @db.Uuid
  title            String
  date             String
  time             String
  location         String?
  locationName     String?  @map("location_name")
  message          String?
  qrEnabled        Boolean  @default(true) @map("qr_enabled")
  guestsEnabled    Boolean  @default(false) @map("guests_enabled")
  reminderEnabled    Boolean   @default(true) @map("reminder_enabled")
  eventDate          DateTime? @map("event_date") @db.Date
  reminderDaysBefore Int       @default(1) @map("reminder_days_before")
  reminderSentAt     DateTime? @map("reminder_sent_at") @db.Timestamptz(6)
  isScheduled        Boolean   @default(false) @map("is_scheduled")
  scheduledAt      DateTime? @map("scheduled_at") @db.Timestamptz(6)
  imageUrl         String?  @map("image_url")
  mediaType        String?  @map("media_type")
  mediaFilename    String?  @map("media_filename")
  locale           String?  @default("en")
  stripePaymentId  String?  @unique @map("stripe_payment_id")
  paidAt           DateTime? @map("paid_at") @db.Timestamptz(6)
  guests           Guest[]

  vendorId            String?  @map("vendor_id") @db.Uuid
  vendor              Vendor?  @relation(fields: [vendorId], references: [id])
  customerEmail       String?  @map("customer_email")
  customerUserId      String?  @map("customer_user_id") @db.Uuid
  customerPermissions Json?    @map("customer_permissions")
  attendantEmails     String[] @default([]) @map("attendant_emails")

  // Denormalized counters (maintained via DB triggers on "guests")
  guestCountTotal      Int @default(0) @map("guest_count_total")

  inviteCountTotal     Int @default(0) @map("invite_count_total")
  inviteCountPending   Int @default(0) @map("invite_count_pending")
  inviteCountSent      Int @default(0) @map("invite_count_sent")
  inviteCountDelivered Int @default(0) @map("invite_count_delivered")
  inviteCountRead      Int @default(0) @map("invite_count_read")
  inviteCountConfirmed Int @default(0) @map("invite_count_confirmed")
  inviteCountDeclined  Int @default(0) @map("invite_count_declined")
  inviteCountFailed    Int @default(0) @map("invite_count_failed")
  inviteCountNoReply   Int @default(0) @map("invite_count_no_reply")

  editingUnlocked      Boolean @default(false) @map("editing_unlocked")

  affiliateCommission AffiliateCommission?

  @@index([userId, createdAt])
  @@index([vendorId])
  @@index([customerEmail])
  @@index([customerUserId])
  @@index([eventDate, reminderEnabled])
  @@map("events")
}

model Affiliate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  code           String   @unique
  name           String
  contactEmail   String?  @map("contact_email")
  contactPhone   String?  @map("contact_phone")
  commissionFils Int      @default(10000) @map("commission_fils")
  active         Boolean  @default(true)
  notes          String?
  clickCount     Int      @default(0) @map("click_count")

  attributions AffiliateAttribution[]
  commissions  AffiliateCommission[]

  @@map("affiliates")
}

model AffiliateAttribution {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  userId      String    @unique @map("user_id") @db.Uuid
  affiliateId String    @map("affiliate_id") @db.Uuid
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@map("affiliate_attributions")
}

model AffiliateCommission {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  affiliateId String  @map("affiliate_id") @db.Uuid
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Restrict)
  userId      String    @unique @map("user_id") @db.Uuid
  eventId     String    @unique @map("event_id") @db.Uuid
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Restrict)
  amountFils  Int       @map("amount_fils")
  status      String    @default("owed")
  paidAt      DateTime? @map("paid_at") @db.Timestamptz(6)
  payoutNote  String?   @map("payout_note")

  @@index([affiliateId, status])
  @@map("affiliate_commissions")
}

model Guest {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  eventId            String   @map("event_id") @db.Uuid
  event              Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name               String
  phone              String
  inviteCount        Int      @default(1) @map("invite_count")
  status             String   @default("no_reply")
  sentAt             DateTime? @map("sent_at") @db.Timestamptz(6)
  deliveredAt        DateTime? @map("delivered_at") @db.Timestamptz(6)
  readAt             DateTime? @map("read_at") @db.Timestamptz(6)
  confirmedAt        DateTime? @map("confirmed_at") @db.Timestamptz(6)
  declinedAt         DateTime? @map("declined_at") @db.Timestamptz(6)
  failedAt           DateTime? @map("failed_at") @db.Timestamptz(6)
  whatsappMessageId  String?  @unique @map("whatsapp_message_id")
  whatsappSendEnqueuedAt DateTime? @map("whatsapp_send_enqueued_at") @db.Timestamptz(6)
  whatsappSendAttempts   Int      @default(0) @map("whatsapp_send_attempts")
  whatsappSendLastError  String?  @map("whatsapp_send_last_error")
  noReplyReminderSentAt      DateTime? @map("no_reply_reminder_sent_at") @db.Timestamptz(6)
  noReplyReminderDeliveredAt DateTime? @map("no_reply_reminder_delivered_at") @db.Timestamptz(6)
  noReplyReminderReadAt      DateTime? @map("no_reply_reminder_read_at") @db.Timestamptz(6)
  noReplyReminderFailedAt    DateTime? @map("no_reply_reminder_failed_at") @db.Timestamptz(6)
  noReplyReminderMessageId   String?   @map("no_reply_reminder_message_id")
  checkedIn          Boolean  @default(false) @map("checked_in")
  checkedInAt        DateTime? @map("checked_in_at") @db.Timestamptz(6)
  qrCodeId           String?  @unique @map("qr_code_id")

  // Query hot-paths:
  // - listing guests by eventId ordered by createdAt
  // - grouping/counting by status within an event
  // - counting guests per event (pagination + stats)
  @@unique([eventId, phone])
  @@index([eventId])
  @@index([eventId, status])
  @@index([eventId, createdAt])
  @@map("guests")
}

model WhatsAppMessage {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  phone            String
  direction        String   // "inbound" or "outbound"
  body             String
  messageType      String   @default("text") @map("message_type") // text, button, image, etc.
  whatsappMessageId String? @unique @map("whatsapp_message_id")
  contextMessageId String?  @map("context_message_id") // the message this is replying to
  guestId          String?  @map("guest_id") @db.Uuid
  guestName        String?  @map("guest_name")
  status           String   @default("sent") // for outbound: sent, delivered, read, failed
  needsReply       Boolean  @default(false) @map("needs_reply") // true for inbound msgs requiring admin attention
  vendorId         String?  @map("vendor_id") @db.Uuid

  @@index([phone, createdAt])
  @@index([phone, needsReply])
  @@index([createdAt])
  @@index([vendorId])
  @@map("whatsapp_messages")
}
